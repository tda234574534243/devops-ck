# =============================================
# API
# =============================================

# Base URL of the .NET backend API.
# Must end without trailing slash.
# Local dev default: http://localhost:5235/api
VITE_API_URL=http://localhost:5235/api

# =============================================
# Google OAuth/OIDC Login
# =============================================

# Google OAuth Web Client ID (from Google Cloud Console)
# Example: 1234567890-abcde12345.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=

# Must match one of Authorized redirect URIs in Google Cloud Console
# Local dev default:
VITE_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# =============================================
# Optional: AI Features (Gemini)
# =============================================

# Required only if Gemini AI features are used.
# Get your key at: https://aistudio.google.com/app/apikey
# Leave blank to disable AI features.
GEMINI_API_KEY=
