Vagrant.configure("2") do |config|

  # Basic VM
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "production-server"

  # Sync the production-machine host folder into the VM at /home/vagrant/app
  host_app = File.expand_path('..', __dir__)
  config.vm.synced_folder host_app, "/home/vagrant/app", owner: "vagrant", group: "vagrant"

  # Private network IP (same as previous setup)
  config.vm.network "private_network", ip: "192.168.56.11"

  # Provider settings
  config.vm.provider "virtualbox" do |vb|
    vb.memory = 2048
    vb.cpus = 2
  end

  # Forward useful ports to host (optional) — you can access via 192.168.56.11 as well
  config.vm.network "forwarded_port", guest: 80, host: 8080, auto_correct: true
  config.vm.network "forwarded_port", guest: 5000, host: 5001, auto_correct: true
  config.vm.network "forwarded_port", guest: 1433, host: 1433, auto_correct: true

  # Provision: install Docker, Docker Compose plugin and run deploy script
  config.vm.provision "shell", privileged: true, inline: <<-SHELL
    set -euxo pipefail
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -y
    apt-get install -y apt-transport-https ca-certificates curl gnupg lsb-release

    if ! command -v docker >/dev/null 2>&1; then
      curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
      echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" > /etc/apt/sources.list.d/docker.list
      apt-get update -y
      apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
    fi

    systemctl enable docker
    systemctl restart docker
    sleep 5

    # Add vagrant user to docker group
    if ! groups vagrant | grep -q docker; then
      usermod -aG docker vagrant || true
    fi

    # Ensure app dir exists (synced folder should already be mounted)
    mkdir -p /home/vagrant/app
    chown -R vagrant:vagrant /home/vagrant/app || true

    # Make deploy script executable and run it as vagrant user if present
    if [ -f /home/vagrant/app/deploy.sh ]; then
      chmod +x /home/vagrant/app/deploy.sh || true
      sudo -u vagrant bash -lc "cd /home/vagrant/app && ./deploy.sh"
    else
      # Fallback: run docker compose up if compose file exists
      if [ -f /home/vagrant/app/docker-compose.yml ]; then
        sudo -u vagrant bash -lc "cd /home/vagrant/app && docker compose up -d --remove-orphans"
      fi
    fi

    # Ensure cron job exists to run deploy script periodically.
    # The cron line will only execute deploy.sh if it is executable.
    cat > /etc/cron.d/devops-deploy <<'CRON'
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin

*/5 * * * * vagrant [ -x /home/vagrant/app/deploy.sh ] && /home/vagrant/app/deploy.sh >> /home/vagrant/app/deploy.log 2>&1
CRON
    chmod 644 /etc/cron.d/devops-deploy || true
    systemctl enable cron || true
    systemctl restart cron || true

  SHELL

end